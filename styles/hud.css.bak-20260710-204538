.hud {
  display: grid;
  grid-template-columns: repeat(6, minmax(100px, 1fr));
  gap: 8px;
  margin-top: 14px;
}

.hud span {
  padding: 10px 12px;
  border: 1px solid var(--border);
  border-radius: 8px;
  background: var(--surface-raised);
  color: var(--text-muted);
  font-size: 0.82rem;
  text-align: center;
}

@media (max-width: 900px) {
  .hud {
    grid-template-columns: repeat(2, minmax(120px, 1fr));
  }
}
