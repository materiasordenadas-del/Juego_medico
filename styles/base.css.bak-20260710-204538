* {
  box-sizing: border-box;
}

:root {
  font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  color: #edf3f7;
  background: #0c1117;
}

body {
  min-width: 320px;
  min-height: 100vh;
  margin: 0;
}

button,
input,
select {
  font: inherit;
}

code {
  color: #b9d9ee;
}

#app-shell {
  width: min(1500px, 100%);
  margin: 0 auto;
  padding: 20px;
}
